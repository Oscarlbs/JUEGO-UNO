{
  "expo": {
    "name": "UNO Gym",
    "slug": "uno-gym",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "juego-uno",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.juegouno.gym"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.juegouno.gym"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
